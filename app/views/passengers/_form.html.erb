<%= form_with model: [trip, passenger], class: "space-y-4" do |form| %>
  <% if passenger.errors.any? %>
    <div class="py-2 px-3 bg-red-50 text-red-600 rounded-lg" id="error_explanation">
      <h2 class="font-medium"><%= pluralize(passenger.errors.count, "erro") %> impedem salvar:</h2>
      <ul class="list-disc ml-5 mt-1 text-sm">
        <% passenger.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :full_name, "Nome completo", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :full_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <% if passenger.errors[:full_name].any? { |message| message.include?("confirm") } %>
    <div class="flex items-center gap-2 text-sm">
      <%= form.check_box :confirm_name_duplicate, class: "rounded border-gray-300" %>
      <%= form.label :confirm_name_duplicate, "Confirmar nome duplicado na viagem" %>
    </div>
  <% end %>

  <div>
    <%= form.label :cpf, "CPF", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :cpf, value: passenger.cpf.presence || passenger.cpf_display, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :parent_name, "Nome do responsável", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :parent_name, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :parent_phone_number, "Telefone do responsável", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.telephone_field :parent_phone_number, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :parent_email, "E-mail do responsável", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.email_field :parent_email, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :expected_amount_override_minor, "Valor esperado (passageiro, centavos)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.number_field :expected_amount_override_minor, min: 0, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div class="flex flex-wrap gap-3 pt-2">
    <%= form.submit "Salvar", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
    <%= link_to "Cancelar", trip_passengers_path(trip), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium" %>
  </div>
<% end %>
