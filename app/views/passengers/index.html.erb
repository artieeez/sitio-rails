<div class="mx-auto md:w-2/3 w-full">
  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-wrap items-center justify-between gap-4 mb-5">
    <div>
      <p class="text-sm text-gray-500 mb-1"><%= @trip.display_title %></p>
      <h1 class="font-bold text-4xl">Passageiros</h1>
    </div>
    <%= link_to "Adicionar passageiro", new_trip_passenger_path(@trip), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  </div>

  <div class="mb-4 text-sm">
    <% if @include_removed %>
      <%= link_to "Ocultar removidos", trip_passengers_path(@trip), class: "text-gray-700 underline hover:no-underline" %>
    <% else %>
      <%= link_to "Incluir removidos", trip_passengers_path(@trip, include_removed: true), class: "text-gray-700 underline hover:no-underline" %>
    <% end %>
  </div>

  <% if @passengers.any? %>
    <ul class="divide-y divide-gray-200 border border-gray-200 rounded-lg">
      <% @passengers.each do |passenger| %>
        <li class="px-4 py-3 flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="font-medium text-gray-900">
              <%= link_to passenger.full_name, trip_passenger_path(@trip, passenger), class: "underline hover:no-underline" %>
            </p>
            <p class="text-sm text-gray-500 mt-1">
              <%= passenger.cpf_display || "Sem CPF" %>
              · <%= passenger.payment_status_label %>
              <% if passenger.removed? %> · Removido<% end %>
            </p>
          </div>
          <div class="flex flex-wrap gap-3 text-sm">
            <%= link_to "Editar", edit_trip_passenger_path(@trip, passenger), class: "text-gray-700 underline hover:no-underline" %>
            <% if passenger.removed? %>
              <%= button_to "Restaurar", passenger_removal_path(passenger), method: :delete, class: "text-gray-700 underline hover:no-underline cursor-pointer" %>
            <% else %>
              <%= button_to "Excluir", passenger_removal_path(passenger), method: :post, class: "text-red-600 underline hover:no-underline cursor-pointer" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600">Nenhum passageiro ainda.</p>
  <% end %>

  <p class="text-sm mt-6">
    <%= link_to "← Viagem", school_trip_path(@trip.school, @trip), class: "text-gray-700 underline hover:no-underline" %>
  </p>
</div>
