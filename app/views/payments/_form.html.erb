<%= form_with model: [passenger, payment], class: "space-y-4" do |form| %>
  <% if payment.errors.any? %>
    <div class="py-2 px-3 bg-red-50 text-red-600 rounded-lg" id="error_explanation">
      <h2 class="font-medium"><%= pluralize(payment.errors.count, "erro") %> impedem salvar:</h2>
      <ul class="list-disc ml-5 mt-1 text-sm">
        <% payment.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :paid_on, "Data do pagamento", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.date_field :paid_on, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :amount_minor, "Valor (centavos)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.number_field :amount_minor, min: 0, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :location, "Local", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :location, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div>
    <%= form.label :payer_identity, "Identificação do pagador", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= form.text_field :payer_identity, class: "block w-full rounded-md border border-gray-300 px-3 py-2" %>
  </div>

  <div class="flex flex-wrap gap-3 pt-2">
    <%= form.submit "Salvar", class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
    <%= link_to "Cancelar", passenger_payments_path(passenger), class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium" %>
  </div>
<% end %>
