<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-4xl mb-3">Excluir escola</h1>
  <p class="text-gray-600 mb-6">
    Excluir permanentemente <strong><%= @school.display_title %></strong>? Esta ação não pode ser desfeita.
  </p>

  <% if @deletion.allowed? %>
    <p class="text-sm text-gray-500 mb-6">A escola pode ser excluída.</p>
    <%= button_to "Excluir permanentemente", school_deletion_path(@school), method: :delete, class: "rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-500 text-white font-medium cursor-pointer", form: { data: { turbo_confirm: "Confirmar exclusão permanente?" } } %>
  <% else %>
    <p class="text-sm text-red-600 mb-6">A escola não pode ser excluída no momento.</p>
  <% end %>

  <p class="text-sm mt-6">
    <%= link_to "← Voltar", @school, class: "text-gray-700 underline hover:no-underline" %>
  </p>
</div>
