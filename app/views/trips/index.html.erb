<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex flex-wrap items-center justify-between gap-4 mb-5">
    <div>
      <p class="text-sm text-gray-500 mb-1"><%= @school.display_title %></p>
      <h1 class="font-bold text-4xl">Viagens</h1>
    </div>
    <%= link_to "Adicionar viagem", new_school_trip_path(@school), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
  </div>

  <div class="mb-4 text-sm">
    <% if @include_inactive %>
      <%= link_to "Ocultar viagens inativas", school_trips_path(@school), class: "text-gray-700 underline hover:no-underline" %>
    <% else %>
      <%= link_to "Incluir viagens inativas", school_trips_path(@school, include_inactive: true), class: "text-gray-700 underline hover:no-underline" %>
    <% end %>
  </div>

  <% if @trips.any? %>
    <ul class="divide-y divide-gray-200 border border-gray-200 rounded-lg">
      <% @trips.each do |trip| %>
        <li class="px-4 py-3">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="font-medium text-gray-900">
                <%= link_to trip.display_title, school_trip_path(@school, trip), class: "underline hover:no-underline" %>
              </p>
              <p class="text-sm text-gray-500 mt-1">
                <% if trip.deactivated? %>Inativa<% else %>Ativa<% end %>
                ·
                <% if trip.store_concealed? %>Oculta na loja<% else %>Visível na loja<% end %>
                <% if trip.expiration_date.present? %>
                  · Expira em <%= l(trip.expiration_date, format: :short) %>
                <% end %>
              </p>
            </div>
            <div class="flex flex-wrap gap-3 text-sm">
              <%= link_to "Editar", edit_school_trip_path(@school, trip), class: "text-gray-700 underline hover:no-underline" %>
              <% if trip.deactivated? %>
                <%= button_to "Ativar", trip_deactivation_path(trip), method: :delete, class: "text-gray-700 underline hover:no-underline cursor-pointer" %>
              <% else %>
                <%= button_to "Desativar", trip_deactivation_path(trip), method: :post, class: "text-gray-700 underline hover:no-underline cursor-pointer" %>
              <% end %>
              <%= link_to "Excluir", trip_deletion_path(trip), class: "text-red-600 underline hover:no-underline" %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-gray-600">Nenhuma viagem ainda.</p>
  <% end %>

  <p class="text-sm mt-6">
    <%= link_to "← Escola", @school, class: "text-gray-700 underline hover:no-underline" %>
  </p>
</div>
